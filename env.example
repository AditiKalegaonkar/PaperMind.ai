# ──────────────────────────────────────────────────────────────
# Google API / Gemini
# ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Google OAuth (used by server.js / passport.js for "Login with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK=

# ──────────────────────────────────────────────────────────────
# Node Backend (server.js)
# ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
SESSION_SECRET=your_secret_key_here
MONGO_URI=                          # Mongoose connection string — read by server.js only

# ──────────────────────────────────────────────────────────────
# Python Backend (main.py)
# ──────────────────────────────────────────────────────────────
FAST_API_PORT=8000
MONGODB_URL=                        # Same MongoDB cluster as MONGO_URI above —
                                     # different variable name because main.py (Motor)
                                     # and server.js (Mongoose) each read their own name.

# ──────────────────────────────────────────────────────────────
# Cross-service URLs
# ──────────────────────────────────────────────────────────────
# server.js proxies chat requests to the Python backend using this.
# NOTE: the code currently reads this as FLASK_API_URL (not FASTAPI_URL) —
# keep this name unless you've also updated server.js line 28 to match.
FLASK_API_URL=

# Frontend origin — used by server.js for CORS + OAuth redirect target.
FRONTEND_URL=
